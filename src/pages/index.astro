---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Products from '../components/Products.astro'
import Features from '../components/Features.astro';
import UseCases from '../components/UseCases.astro';
import Specs from '../components/Specs.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const t = useTranslations('en');
---

<Layout
  title="Wall & Roof Panels — High Performance Structural Insulated Panels"
  description="Fast installation, superior thermal insulation and structural strength for industrial buildings, warehouses and commercial facilities."
>
	<Nav t={t} lang="en" />

	<Hero t={t} />
	<Stats t={t} />
	<Products t={t} />
	<Features t={t} />
	<UseCases t={t} />
	<Specs t={t} />
	<CTA t={t} />
	
	<Footer t={t} lang='en' />

</Layout>