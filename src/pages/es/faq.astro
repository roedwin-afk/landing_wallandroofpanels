---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
import CTA from '../../components/CTA.astro';

const t = useTranslations('es');
const faq = t.faq;
---

<Layout
  title="Preguntas Frecuentes sobre Paneles Aislados — PIR vs PUR, Resistencia al Fuego, Espesor"
  description="Respuestas sobre paneles estructurales aislados: PIR vs PUR vs lana mineral, resistencia al fuego, selección de espesor, tiempo de instalación y aplicaciones en cadena de frío."
>
  <section class="faq-hero">
    <div class="faq-hero-inner">
      <p class="eyebrow">{faq.eyebrow}</p>
      <h1>{faq.title}</h1>
      <p class="intro">{faq.intro}</p>
    </div>
  </section>

  <section class="faq-list-section">
    <div class="faq-list">
      {faq.items.map((item) => (
        <details class="faq-item">
          <summary>
            <span>{item.q}</span>
            <span class="icon" aria-hidden="true"></span>
          </summary>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <CTA t={t} />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faq.items.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    })}
  />
</Layout>

<style>
  .faq-hero {
    background: linear-gradient(180deg, var(--green-dark), var(--green-mid));
    padding: 96px 24px 72px;
  }
  .faq-hero-inner {
    max-width: min(1200px, calc(100% - 2.5rem));
    margin: 0 auto;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--green-light);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .faq-hero h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .intro {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .faq-list-section {
    padding: 64px 24px;
  }
  .faq-list {
    max-width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    background: var(--white);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 4px 8px;
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 16px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: #1a1a1a;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    position: relative;
  }
  .icon::before,
  .icon::after {
    content: "";
    position: absolute;
    background: var(--green-primary);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .icon::before {
    width: 14px;
    height: 2px;
  }
  .icon::after {
    width: 2px;
    height: 14px;
    transition: transform 0.15s ease;
  }
  .faq-item[open] .icon::after {
    transform: translate(-50%, -50%) rotate(90deg) scaleY(0);
  }
  .faq-answer {
    padding: 0 16px 20px;
  }
  .faq-answer p {
    color: #4a4a4a;
    font-size: 0.95rem;
    line-height: 1.65;
  }
</style>