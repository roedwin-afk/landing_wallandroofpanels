import { useTranslations } from '../../i18n/utils';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ProductPage from '../../components/ProductPage.astro';

const t = useTranslations('es');
---

<Layout
  title="Productos | WallAndRoofPanels.com"
  description="Explora paneles aislados para muro, techo y cuartos fríos para proyectos industriales y comerciales."
>
  <Nav t={t} lang="es" />

  <ProductPage t={t} lang='es' />
  
  <Footer t={t} lang='es' />

</Layout>