---
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import BlogList from "../../../components/BlogList.astro";
import { MOCK_POSTS } from "../../../data/posts";

import { useTranslations } from '../../../i18n/utils';
const t = useTranslations('es');


const POSTS_PER_PAGE = 5;
const allPosts = MOCK_POSTS;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const base = import.meta.env.BASE_URL;

const locale = Astro.currentLocale ?? 'es';
const basePath = locale === 'es' ? `${base}es/blog/page/` : `${base}blog/page/`;
---

<Layout
  title="Blog | Panel for Cold Room"
  description="Artículos sobre paneles para cámaras frigoríficas, aislamiento industrial y proyectos de refrigeración en México."
>
  <Nav t={t} lang="es"/>
  <BlogList
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    basePath={basePath}
    t={t}
    locale={locale}
  />
  <Footer t={t} lang="es"/>
</Layout>