---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import { MOCK_POSTS_ES } from "../../../data/posts_es";

import { en } from "../../../i18n/en";
import { es } from "../../../i18n/es";


const locale = Astro.currentLocale ?? "es";
const t = es;
const lang = "es";

export async function getStaticPaths() {
  return MOCK_POSTS_ES.map((post) => ({
    params: { slug: post.slug },  // Astro lo maneja bien con rest params también
    props: { post },
  }));
}
console.log("All posts:", MOCK_POSTS_ES);
// export async function getStaticPaths() {
//   const response = await fetch(`${import.meta.env.WORDPRESS_API_URL}/posts?_embed&per_page=100`);
//   const posts = await response.json();
//
//   return posts.map((post: any) => ({
//     params: { slug: post.slug },
//     props: { post },
//   }));
// }

const { post } = Astro.props as { post: any };
---

<Layout
  title={`${post.title.rendered} | Panel For Cold Room`}
  description={post.excerpt.rendered.replace(/<[^>]*>/g, "").trim()}
>
  <Nav t={t} lang={lang} disableLangSwitch={true} />

  <main class="post">
    <p style="color: red;">{Astro.currentLocale}</p>
    <article class="post__container">
      <header class="post__header">
        <p class="post__date">
          {new Date(post.date).toLocaleDateString("es-ES", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </p>

        <h1 class="post__title" set:html={post.title.rendered} />
      </header>

      {post._embedded?.["wp:featuredmedia"]?.[0]?.source_url && (
        <img
          src={post._embedded["wp:featuredmedia"][0].source_url}
          alt={post.title.rendered}
          class="post__image"
        />
      )}

      <div class="post__content" set:html={post.content.rendered} />
    </article>
  </main>

  <Footer t={t} lang={lang} />
</Layout>

<style>
  .post {
    background:
      radial-gradient(circle at top right, rgba(151, 196, 89, 0.16), transparent 34rem),
      var(--green-dark);
    padding: 6rem 2rem 5rem;
    font-family: var(--font-body);
    min-height: 100vh;
  }

  .post__container {
    max-width: 920px;
    margin: 0 auto;
  }

  .post__header {
    margin-bottom: 2.5rem;
  }

  .post__date {
    display: inline-flex;
    align-items: center;
    color: var(--green-light);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }

  .post__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.25rem);
    font-weight: 700;
    color: var(--white);
    line-height: 0.9;
    margin: 0;
    text-transform: uppercase;
    max-width: 850px;
  }

  .post__image {
    width: 100%;
    height: min(52vw, 520px);
    object-fit: cover;
    border-radius: 18px;
    margin: 0 0 2.5rem;
    border: 1px solid var(--border-subtle);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  }

  .post__content {
    background: var(--green-mid);
    color: var(--text-muted);
    line-height: 1.8;
    font-size: 1.05rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    border: 1px solid var(--border-subtle);
    border-radius: 18px;
  }

  .post__content :global(h2),
  .post__content :global(h3),
  .post__content :global(h4) {
    font-family: var(--font-display);
    color: var(--white);
    line-height: 1;
    text-transform: uppercase;
    margin: 2.4rem 0 1rem;
  }

  .post__content :global(h2) {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .post__content :global(h3) {
    font-size: 2rem;
  }

  .post__content :global(p) {
    margin: 0 0 1.15rem;
  }

  .post__content :global(strong) {
    color: var(--white);
  }

  .post__content :global(a) {
    color: var(--green-light);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .post__content :global(ul),
  .post__content :global(ol) {
    padding-left: 1.3rem;
    margin: 0 0 1.4rem;
  }

  .post__content :global(li) {
    margin-bottom: 0.55rem;
  }

  .post__content :global(img) {
    display: block;
    width: 100%;
    max-width: 100%;
    border-radius: 14px;
    margin: 2rem 0;
    border: 1px solid var(--border-subtle);
  }

  .post__content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--green-light);
    background: rgba(255, 255, 255, 0.04);
    color: var(--white);
    border-radius: 0 12px 12px 0;
  }

  .post__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    overflow: hidden;
    border-radius: 12px;
  }

  .post__content :global(th),
  .post__content :global(td) {
    border: 1px solid var(--border-subtle);
    padding: 0.9rem;
    text-align: left;
  }

  .post__content :global(th) {
    background: var(--green-primary);
    color: var(--white);
  }

  .post__content :global(td) {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .post {
      padding: 4rem 1.25rem 3rem;
    }

    .post__title {
      font-size: clamp(2.6rem, 16vw, 4rem);
    }

    .post__image {
      height: 260px;
      border-radius: 14px;
    }

    .post__content {
      padding: 1.25rem;
      border-radius: 14px;
      font-size: 1rem;
    }
  }
</style>