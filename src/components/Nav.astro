---
import type { TranslationKeys } from "../i18n/en";
import { Image } from "astro:assets";
import type { Lang } from "../i18n/utils";
import Menu from "./Menu.astro";

import logo from "../assets/logo.svg";

interface Props {
  t: TranslationKeys;
  lang: Lang;
  disableLangSwitch?: boolean;
}

const { t, lang, disableLangSwitch = false } = Astro.props;
const alternateLang = lang === "en" ? "es" : "en";

const base = import.meta.env.BASE_URL;
const homeHref = lang === "es" ? `${base}es/` : base;
const contactHref = lang === "es" ? `${base}es/contact/` : `${base}contact/`;

// Alternate path inteligente basado en la URL actual
const currentPath = Astro.url.pathname;
const pathWithoutBase = currentPath.replace(base, "") || "";
const cleanPath = pathWithoutBase.replace(/^es\//, "");
const alternatePath =
  lang === "es" ? `${base}${cleanPath}` : `${base}es/${cleanPath}`;
---

<header class="nav">
  <div class="nav-logo">
    <a href={homeHref} class="navbar__brand" aria-label="Go to home">
      <Image
        src={logo}
        alt="Panel sándwich para techo industrial"
        width={200}
        height={50}
        class="nav__logo-img"
        format="webp"
        quality={85}
        loading="eager"
      />
    </a>
  </div>

  <Menu t={t} lang={lang} variant="nav" />

  <div class="nav-right">
    <!-- Cambia el link por un span si está deshabilitado -->
    {
      disableLangSwitch ? (
        <span class="lang-switch lang-switch--disabled">
          {alternateLang.toUpperCase()}
        </span>
      ) : (
        <a
          href={alternatePath}
          class="lang-switch"
          aria-label="Switch language"
        >
          {alternateLang.toUpperCase()}
        </a>
      )
    }

    <a href={contactHref} class="nav-cta">
      {t.nav.cta}
    </a>

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<Menu t={t} lang={lang} variant="mobile" />

<style>
  .nav {
    background: #0c1a14;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: #fff;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  .nav__logo-img {
    display: block;
    height: 2.5rem;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .nav-logo-accent {
    color: #3b6d11;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: #97c459;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .lang-switch {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 1px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 4px 10px;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .lang-switch:hover {
    color: #97c459;
    border-color: #97c459;
  }

  .nav-cta {
    background: #3b6d11;
    color: #fff;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 600;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .nav-cta:hover {
    background: #4a8a15;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.3s;
  }

  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: #0c1a14;
    padding: 1rem 2rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    position: sticky;
    top: 60px;
    z-index: 99;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-menu a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 15px;
    font-weight: 500;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 0.2s;
  }

  .mobile-menu a:hover {
    color: #97c459;
  }

  .mobile-lang {
    color: rgba(255, 255, 255, 0.4) !important;
    font-size: 13px !important;
  }

  .mobile-cta {
    margin-top: 1rem;
    background: #3b6d11;
    color: #fff !important;
    padding: 12px 0 !important;
    text-align: center;
    border-radius: 4px;
    font-weight: 600 !important;
    border-bottom: none !important;
  }

  .lang-switch--disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .lang-switch {
      display: none;
    }
    .nav-cta {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.getElementById("hamburger");
  const mobileMenu = document.getElementById("mobile-menu");

  hamburger?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("open");
    hamburger.classList.toggle("open");
    hamburger.setAttribute("aria-expanded", String(isOpen));
    mobileMenu?.setAttribute("aria-hidden", String(!isOpen));
  });

  // Cierra el menu al hacer click en cualquier link
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.remove("open");
      hamburger?.classList.remove("open");
      hamburger?.setAttribute("aria-expanded", "false");
      mobileMenu.setAttribute("aria-hidden", "true");
    });
  });
</script>
