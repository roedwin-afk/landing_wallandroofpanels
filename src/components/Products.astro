---
import type { TranslationKeys } from "../i18n/en";
import { Image } from "astro:assets";

import roofPanelImg from "../assets/images/roof_panel.avif";
import wallPanelImg from "../assets/images/wall_panel.jpg";
import coldRoomImg from "../assets/images/cold_room.jpg";

interface Props {
    t: TranslationKeys;
    lang?: "en" | "es";
}

const { t, lang = "en" } = Astro.props;

const products = [
    {
        name: t.products.p1_name,
        desc: t.products.p1_desc,
        badges: [t.products.badge_structural, t.products.badge_thermal],
        image: wallPanelImg,
        alt:
            lang === "es"
                ? "Panel de pared tipo sándwich para cerramientos industriales"
                : "Sandwich wall panel for industrial enclosures",
    },
    {
        name: t.products.p2_name,
        desc: t.products.p2_desc,
        badges: [t.products.badge_structural, t.products.badge_fire],
        image: roofPanelImg,
        alt:
            lang === "es"
                ? "Panel de techo aislado para cubiertas industriales"
                : "Insulated roof panel for industrial roofing systems",
    },
    {
        name: t.products.p3_name,
        desc: t.products.p3_desc,
        badges: [t.products.badge_thermal, t.products.badge_acoustic],
        image: coldRoomImg,
        alt:
            lang === "es"
                ? "Panel para cuarto frío con vista técnica de instalación"
                : "Cold room panel with technical installation view",
    },
];
---

<section class="products" id="products">
    <div class="products__inner">
        <div class="products__head">
            <p class="products__eyebrow">{t.products.eyebrow}</p>
            <h2 class="products__title">{t.products.title}</h2>
        </div>

        <div class="products__grid">
            {
                products.map((product) => (
                    <article class="product-card">
                        <div class="product-card__media">
                            <Image
                                src={product.image}
                                alt={product.alt}
                                class="product-card__image"
                                widths={[400, 600, 800]}
                                sizes="(max-width: 960px) 100vw, 33vw"
                                loading="lazy"
                            />
                        </div>

                        <div class="product-card__body">
                            <h3 class="product-card__name">{product.name}</h3>
                            <p class="product-card__desc">{product.desc}</p>

                            <div class="product-card__badges">
                                {product.badges.map((badge) => (
                                    <span class="product-card__badge">
                                        {badge}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    .products {
        padding: 5rem 0;
        background: #f4f4f2;
    }

    .products__inner {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
    }

    .products__head {
        margin-bottom: 2rem;
        max-width: 42rem;
    }

    .products__eyebrow {
        margin: 0 0 0.5rem;
        font-size: 0.72rem;
        line-height: 1;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 600;
        color: var(--green-primary);
    }

    .products__title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(2.2rem, 5vw, 3.2rem);
        line-height: 0.98;
        font-weight: 700;
        color: var(--green-dark);
        text-transform: uppercase;
    }

    .products__grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .product-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid rgba(12, 26, 20, 0.08);
        border-radius: 1rem;
        background: var(--white);
        box-shadow: 0 14px 34px rgba(12, 26, 20, 0.05);
        transition:
            transform 0.22s ease,
            box-shadow 0.22s ease,
            border-color 0.22s ease;
    }

    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 22px 44px rgba(12, 26, 20, 0.08);
        border-color: rgba(59, 109, 17, 0.14);
    }

    .product-card__media {
        aspect-ratio: 4 / 3; /* 🔥 más balanceado */
        background: #f7f8f5;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem;
        border-bottom: 1px solid rgba(12, 26, 20, 0.06);
    }

    .product-card__image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-card__image {
        transform: scale(1.03);
    }

    .product-card__body {
        padding: 1.25rem 1.25rem 1.35rem;
        
    }

    .product-card__name {
        margin: 0 0 0.45rem;
        font-family: var(--font-display);
        font-size: 1.6rem;
        line-height: 1;
        font-weight: 700;
        color: var(--green-dark);
        text-transform: uppercase;
    }

    .product-card__desc {
        margin: 0 0 1rem;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #4e5a53;
    }

    .product-card__badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .product-card__badge {
        display: inline-flex;
        align-items: center;
        min-height: 1.8rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: var(--green-pale);
        color: var(--green-deep);
        font-size: 0.72rem;
        line-height: 1;
        font-weight: 700;
        white-space: nowrap;
    }

    @media (max-width: 960px) {
        .products {
            padding: 4rem 1rem;
        }

        .products__grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }

    @media (max-width: 640px) {
        .products__inner {
            width: min(100% - 1.25rem, 1200px);
        }

        .products__head {
            margin-bottom: 1.5rem;
        }

        .product-card__body {
            padding: 1.1rem 1rem 1.15rem;
        }

        .product-card__name {
            font-size: 1.4rem;
        }

        .product-card__desc {
            font-size: 0.92rem;
        }
    }
</style>
