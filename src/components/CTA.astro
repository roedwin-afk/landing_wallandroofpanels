---
import type { TranslationKeys } from "../i18n/en";
const base = import.meta.env.BASE_URL;

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
---

<section class="cta" id="contact">
  <div class="cta__inner">
    <div class="cta__content">
      <p class="cta__eyebrow">{t.cta.eyebrow}</p>
      <h2 class="cta__title">{t.cta.title}</h2>
      <p class="cta__desc">{t.cta.desc}</p>
    </div>

    <div class="cta__actions">
      <a href={`${base}contact`} class="cta__btn cta__btn--primary">
        {t.cta.btn_primary}
      </a>

      <a
        href={`${base}files/Technical Data Sheet.pdf`}
        class="cta__btn cta__btn--outline"
        download
        target="_blank"
        rel="noopener"
      >
        {t.cta.btn_secondary}
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 5rem var(--container-padding, 1.25rem);
    background:
      radial-gradient(
        circle at top right,
        rgba(151, 196, 89, 0.18),
        transparent 32%
      ),
      linear-gradient(
        135deg,
        var(--green-dark) 0%,
        var(--green-mid) 58%,
        var(--green-primary) 100%
      );
  }

  .cta__inner {
    width: min(1100px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
  }

  .cta__content {
    max-width: 680px;
  }

  .cta__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--green-light);
  }

  .cta__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4.5vw, 3.6rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--white);
  }

  .cta__desc {
    margin: 1rem 0 0;
    max-width: 620px;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .cta__actions {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-width: 220px;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.9rem 1.35rem;
    border-radius: 0.35rem;
    font-size: 0.95rem;
    font-weight: 700;
    text-align: center;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .cta__btn:hover {
    transform: translateY(-1px);
  }

  .cta__btn--primary {
    background: var(--green-primary);
    color: var(--white);
    border: 1px solid var(--green-primary);
  }

  .cta__btn--primary:hover {
    background: var(--green-deep);
    border-color: var(--green-deep);
  }

  .cta__btn--outline {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.32);
  }

  .cta__btn--outline:hover {
    border-color: rgba(255, 255, 255, 0.56);
    background: rgba(255, 255, 255, 0.05);
  }

  @media (max-width: 820px) {
    .cta__inner {
      grid-template-columns: 1fr;
    }

    .cta__actions {
      flex-direction: row;
      flex-wrap: wrap;
      min-width: 0;
    }
  }

  @media (max-width: 560px) {
    .cta {
      padding: 4rem var(--container-padding, 1.25rem);
    }

    .cta__actions {
      flex-direction: column;
    }

    .cta__btn {
      width: 100%;
    }
  }
</style>