---
import type { TranslationKeys } from "../i18n/en";
import { Image } from "astro:assets";
import panelDiagram from "../assets/images/panel-diagram.png";
const base = import.meta.env.BASE_URL;

interface Props {
    t: TranslationKeys;
    lang?: "en" | "es";
}

const { t, lang = "en" } = Astro.props;

const panelAlt =
    lang === "es"
        ? "Estructura de panel sándwich con núcleo de poliuretano y láminas de acero"
        : "Sandwich panel structure with polyurethane core and steel sheets";
---

<section class="hero" id="top">
    <div class="hero__inner">
        <div class="hero__content">
            <p class="hero__eyebrow">{t.hero.eyebrow}</p>

            <h1 class="hero__title">
                <span>{t.hero.h1_line1}</span>
                <span>{t.hero.h1_line2}</span>
                <span class="hero__title-accent">{t.hero.h1_accent1}</span>
                <span class="hero__title-join">{t.hero.h1_and}</span>
                <span class="hero__title-accent">{t.hero.h1_accent2}</span>
            </h1>

            <p class="hero__desc">{t.hero.desc}</p>

            <div class="hero__actions">
                <a href={`${base}products`} class="hero__btn hero__btn--primary">
                    {t.hero.btn_primary}
                </a>

                <a
                    href={`${base}files/Technical Data Sheet.pdf`}
                    class="hero__btn hero__btn--outline"
                    download
                    target="_blank"
                    rel="noopener"
                >
                    {t.hero.btn_outline}
                </a>
            </div>
        </div>

        <div class="hero__visual">
            <div class="hero__image-wrap">
                <Image
                    src={panelDiagram}
                    alt={panelAlt}
                    class="hero__image"
                    widths={[420, 580, 640, 800]}
                    sizes="(max-width: 960px) 100vw, 40vw"
                    loading="eager"
                    fetchpriority="high"
                />

                <div class="hero__badges">
                    <span class="hero__badge">{t.hero.badge1}</span>
                    <span class="hero__badge">{t.hero.badge2}</span>
                    <span class="hero__badge">{t.hero.badge3}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        background:
            radial-gradient(
                circle at top right,
                rgba(151, 196, 89, 0.12),
                transparent 26%
            ),
            linear-gradient(
                135deg,
                var(--green-dark) 0%,
                var(--green-mid) 58%,
                #1d4a27 100%
            );
        overflow: hidden;
        padding: 0 1rem;        
    }

    .hero__inner {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        min-height: 34rem;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        gap: 2rem;
        align-items: center;
        padding: 5rem 0 4.5rem;
    }

    .hero__content {
        max-width: 36rem;
    }

    .hero__eyebrow {
        margin-bottom: 0.85rem;
        font-size: 0.72rem;
        line-height: 1;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 600;
        color: var(--green-light);
    }

    .hero__title {
        display: flex;
        flex-direction: column;
        gap: 0.05em;
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(3.2rem, 8vw, 5.4rem);
        line-height: 0.92;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--white);
    }

    .hero__title-accent {
        color: var(--green-light);
    }

    .hero__title-join {
        color: var(--white);
    }

    .hero__desc {
        margin-top: 1.5rem;
        max-width: 34rem;
        font-size: 1rem;
        line-height: 1.7;
        color: var(--text-muted);
    }

    .hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
    }

    .hero__btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 0.9rem 1.4rem;
        border-radius: 0.35rem;
        font-size: 0.95rem;
        font-weight: 600;
        transition:
            background-color 0.2s ease,
            border-color 0.2s ease,
            color 0.2s ease,
            transform 0.2s ease;
    }

    .hero__btn:hover {
        transform: translateY(-1px);
    }

    .hero__btn--primary {
        background: var(--green-primary);
        color: var(--white);
        border: 1px solid var(--green-primary);
    }

    .hero__btn--primary:hover {
        background: var(--green-deep);
        border-color: var(--green-deep);
    }

    .hero__btn--outline {
        background: transparent;
        color: var(--white);
        border: 1px solid rgba(255, 255, 255, 0.32);
    }

    .hero__btn--outline:hover {
        border-color: rgba(255, 255, 255, 0.56);
        background: rgba(255, 255, 255, 0.04);
    }

    .hero__visual {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero__image-wrap {
        width: min(100%, 30rem);
        position: relative;
    }
    .hero__image-wrap::before {
        content: "";
        position: absolute;
        inset: 20% 10%;
        background: radial-gradient(
            circle,
            rgba(151, 196, 89, 0.25),
            transparent 70%
        );
        filter: blur(40px);
        z-index: 0;
    }

    .hero__image {
        display: block;
        width: 100%;
        height: auto;
        filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.35));
        animation: float 6s ease-in-out infinite;
        position: relative;
        z-index: 1;
    }

    @keyframes float {
        0% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-12px);
        }
        100% {
            transform: translateY(0px);
        }
    }

    .hero__badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .hero__badge {
        display: inline-flex;
        align-items: center;
        min-height: 1.8rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: rgba(151, 196, 89, 0.14);
        border: 1px solid rgba(151, 196, 89, 0.18);
        color: var(--green-light);
        font-size: 0.74rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .hero__layer {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.35rem;
        text-align: center;
        font-size: 0.62rem;
        line-height: 1;
        letter-spacing: 0.08em;
        font-weight: 700;
        text-transform: uppercase;
    }

    .hero__layer--top,
    .hero__layer--bottom {
        min-height: 1.45rem;
    }

    .hero__layer--finish {
        background: #c0dd97;
        color: #173404;
    }

    .hero__layer--bottom {
        background: #5f5e5a;
        color: #f1efe8;
    }

    .hero__layer--steel {
        min-height: 0.95rem;
        background: #7f817b;
        color: var(--white);
    }

    .hero__layer--core {
        min-height: 4.9rem;
        background: var(--green-pale);
        color: var(--green-primary);
        border: 1px solid #c0dd97;
    }

    .hero__badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    .hero__badge {
        display: inline-flex;
        align-items: center;
        min-height: 1.8rem;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        background: rgba(151, 196, 89, 0.14);
        border: 1px solid rgba(151, 196, 89, 0.18);
        color: var(--green-light);
        font-size: 0.74rem;
        font-weight: 600;
        white-space: nowrap;
    }

    @media (max-width: 960px) {
        .hero__inner {
            grid-template-columns: 1fr;
            min-height: auto;
            padding: 4.5rem 0 4rem;
        }

        .hero__content {
            max-width: none;
        }

        .hero__visual {
            justify-content: flex-start;
        }

        .hero__diagram-wrap {
            width: min(100%, 28rem);
        }
    }

    @media (max-width: 640px) {
        .hero__inner {
            width: min(100% - 1.25rem, 1200px);
            padding: 4rem 0 3.25rem;
            gap: 1.6rem;
        }

        .hero__title {
            font-size: clamp(2.6rem, 14vw, 4rem);
        }

        .hero__desc {
            font-size: 0.95rem;
            line-height: 1.65;
        }

        .hero__actions {
            flex-direction: column;
            align-items: stretch;
        }

        .hero__btn {
            width: 100%;
        }

        .hero__diagram-wrap {
            padding: 1rem;
            border-radius: 0.8rem;
        }

        .hero__badges {
            gap: 0.45rem;
        }

        .hero__badge {
            font-size: 0.7rem;
        }
    }
</style>
