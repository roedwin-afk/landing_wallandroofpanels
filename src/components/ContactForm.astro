---
import type { TranslationKeys } from "../i18n/en";
import { Mail, Phone, MapPin } from "lucide-astro";

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
---

<section class="contact" id="contact">
  <div class="contact__container">
    <div class="contact__info">
      <p class="contact__eyebrow">{t.form_contact.eyebrow}</p>
      <h1 class="contact__title">{t.form_contact.title}</h1>
      <p class="contact__desc">{t.form_contact.description}</p>

      <div class="contact__data">
        <a href="mailto:info@wallandroofpanels.com" class="contact__item">
          <Mail size={19} />
          <span>info@wallandroofpanels.com</span>
        </a>

        <a href="tel:+525599903546" class="contact__item">
          <Phone size={19} />
          <span>+52 55 9990 3546</span>
        </a>

        <a
          href="https://maps.google.com/?cid=15759084979067732314"
          target="_blank"
          rel="noopener"
          class="contact__item"
        >
          <MapPin size={19} />
          <span>
            Avenida Presidente Masaryk No. 61, Int. 901, Polanco V Sección,
            C.P. 11560, Miguel Hidalgo, Mexico City, Mexico
          </span>
        </a>
      </div>

      <div class="contact__social">
        <a href="#" target="_blank" rel="noopener" aria-label="Facebook">
          Facebook
        </a>
        <a href="#" target="_blank" rel="noopener" aria-label="Instagram">
          Instagram
        </a>
        <a href="#" target="_blank" rel="noopener" aria-label="LinkedIn">
          LinkedIn
        </a>
        <a
          href="https://wa.me/525599903546"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
        >
          WhatsApp
        </a>
      </div>

      <div class="contact__map">
        <div id="contact-map"></div>
      </div>
    </div>

    <form
      class="contact__form"
      action="https://formspree.io/f/maqlkvyj"
      method="POST"
    >
      <input type="hidden" name="_next" value="/thank-you" />

      <div class="form__row">
        <div class="form__group">
          <label for="first-name">{t.form_contact.fields.firstName}</label>
          <input
            type="text"
            id="first-name"
            name="first_name"
            placeholder={t.form_contact.fields.firstName}
            required
          />
        </div>

        <div class="form__group">
          <label for="last-name">{t.form_contact.fields.lastName}</label>
          <input
            type="text"
            id="last-name"
            name="last_name"
            placeholder={t.form_contact.fields.lastName}
            required
          />
        </div>
      </div>

      <div class="form__group">
        <label for="email">{t.form_contact.fields.email}</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder={t.form_contact.fields.email_placeholder}
          required
        />
      </div>

      <div class="form__group">
        <label for="phone">{t.form_contact.fields.phone}</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder={t.form_contact.fields.phone_placeholder}
        />
      </div>

      <div class="form__group">
        <label for="message">{t.form_contact.fields.message}</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder={t.form_contact.fields.message_placeholder}
          required></textarea>
      </div>

      <button type="submit">{t.form_contact.submit}</button>
    </form>
  </div>
</section>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" defer></script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const mapContainer = document.getElementById("contact-map");

    if (!mapContainer || typeof window === "undefined" || !window.L) return;

    const lat = 19.4326;
    const lng = -99.1946;

    const customIcon = window.L.icon({
      iconUrl:
        "https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-green.png",
      shadowUrl:
        "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      shadowSize: [41, 41],
    });

    const map = window.L.map("contact-map").setView([lat, lng], 16);

    window.L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors",
    }).addTo(map);

    window.L.marker([lat, lng], { icon: customIcon })
      .addTo(map)
      .bindPopup("Masaryk 61, Int. 901, Polanco V, CDMX")
      .openPopup();

    setTimeout(() => {
      map.invalidateSize();
    }, 200);
  });
</script>

<style>
  .contact {
    padding: 5rem var(--container-padding, 1.25rem);
    background:
      radial-gradient(
        circle at top right,
        rgba(151, 196, 89, 0.1),
        transparent 30%
      ),
      #f4f4f2;
  }

  .contact__container {
    width: min(1100px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 2rem;
    align-items: start;
  }

  .contact__info,
  .contact__form {
    border-radius: 1rem;
    background: #ffffff;
    border: 1px solid rgba(19, 52, 31, 0.08);
    box-shadow: 0 20px 50px rgba(16, 24, 20, 0.06);
  }

  .contact__info {
    padding: 2rem;
  }

  .contact__form {
    padding: 2rem;
  }

  .contact__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--green-primary);
  }

  .contact__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--green-dark);
  }

  .contact__desc {
    margin: 1rem 0 0;
    font-size: 1rem;
    line-height: 1.75;
    color: #4d5652;
  }

  .contact__data {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.6rem;
  }

  .contact__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem;
    border-radius: 0.75rem;
    background: rgba(151, 196, 89, 0.07);
    border: 1px solid rgba(151, 196, 89, 0.14);
    color: var(--green-dark);
    font-weight: 600;
    line-height: 1.5;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact__item:hover {
    transform: translateY(-1px);
    background: rgba(151, 196, 89, 0.12);
    border-color: rgba(151, 196, 89, 0.28);
  }

  .contact__item svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--green-primary);
  }

  .contact__social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.4rem;
  }

  .contact__social a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: #0c1a14;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 700;
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact__social a:hover {
    transform: translateY(-1px);
    color: var(--green-light);
    background: var(--green-mid);
  }

  .contact__map {
    margin-top: 1.4rem;
    overflow: hidden;
    border-radius: 0.85rem;
    border: 1px solid rgba(19, 52, 31, 0.08);
  }

  #contact-map {
    width: 100%;
    height: 240px;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form__group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form__group label {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-dark);
  }

  .contact__form input,
  .contact__form textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(19, 52, 31, 0.14);
    border-radius: 0.55rem;
    background: #f8faf7;
    color: #172019;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }

  .contact__form textarea {
    resize: vertical;
    min-height: 150px;
  }

  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: none;
    border-color: var(--green-primary);
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(151, 196, 89, 0.18);
  }

  .contact__form button {
    margin-top: 0.25rem;
    min-height: 3.15rem;
    padding: 0.95rem 1.35rem;
    border: 1px solid var(--green-primary);
    border-radius: 0.35rem;
    background: var(--green-primary);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 800;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }

  .contact__form button:hover {
    transform: translateY(-1px);
    background: var(--green-deep);
    border-color: var(--green-deep);
  }

  .leaflet-popup-content-wrapper {
    border-radius: 0.7rem;
    font-family: var(--font-body);
  }

  .leaflet-popup-content {
    color: var(--green-dark);
    font-size: 0.9rem;
  }

  .leaflet-control-attribution {
    font-size: 10px;
    opacity: 0.7;
  }

  @media (max-width: 900px) {
    .contact__container {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact {
      padding: 4rem var(--container-padding, 1.25rem);
    }

    .contact__info,
    .contact__form {
      padding: 1.35rem;
      border-radius: 0.85rem;
    }

    .form__row {
      grid-template-columns: 1fr;
    }

    #contact-map {
      height: 220px;
    }
  }
</style>