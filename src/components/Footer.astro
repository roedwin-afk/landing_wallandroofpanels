---
import type { TranslationKeys } from "../i18n/en";
import Menu from "./Menu.astro";

import { Image } from "astro:assets";
import logo from "../assets/logo.svg";

interface Props {
  t: TranslationKeys;
  lang: "en" | "es";
}

const { t, lang } = Astro.props;
const base = import.meta.env.BASE_URL + (lang === "en" ? "" : `${lang}/`);
---

<footer class="footer">
  <div class="footer__inner">
    <!-- <a href="#top" class="footer__brand" aria-label={t.footer.brand}>
      Wall<span>&</span>Roof<span>Panels</span>.com
    </a> -->
    <a href={`${base}`} class="footer__brand" aria-label="Ir al inicio">
      <Image
        src={logo}
        alt="Panel sándwich para techo industrial"
        width={200}
        height={50}
        class="footer__logo-img"
        format="webp"
        quality={85}
        loading="eager"
      />
    </a>

    <Menu t={t} lang={lang} variant="footer" class="footer__menu" />

    <p class="footer__copy">{t.footer.copy}</p>
  </div>
</footer>

<style>
  footer {
    margin-top: auto;
  }
  .footer {
    background: #0c1a14;
    padding: 1rem var(--container-padding, 1.25rem);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__inner {
    width: min(1200px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__brand {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--white);
    white-space: nowrap;
  }

  .footer__logo-img {
    display: block;
    height: 2.5rem;
    width: auto;
    filter: brightness(0) invert(1);
  }

  .footer__copy {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.32);
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 900px) {
  .footer {
    padding: 2.5rem var(--container-padding, 1.25rem); /* más aire */
  }

  .footer__inner {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    text-align: left;
    gap: 1.5rem;
  }

  .footer__brand {
    grid-column: 1;
    grid-row: 1;
  }

  .footer__menu {
    grid-column: 2;
    grid-row: 1 / 3;
    align-items: flex-end;
  }

  .footer__copy {
    grid-column: 1;
    grid-row: 2;
    text-align: left;
    white-space: normal;
    color: rgba(255, 255, 255, 0.45); /* un poco más visible */
    font-size: 0.75rem;
  }
}

  @media (max-width: 520px) {
    .footer {
      padding: 1.75rem var(--container-padding, 1.25rem);
    }

    .footer__links {
      flex-direction: column;
      gap: 0.65rem;
    }
  }
</style>
