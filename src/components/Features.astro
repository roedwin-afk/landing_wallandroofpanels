---
import type { TranslationKeys } from '../i18n/en';
import { Zap, Shield, Clock3, Users } from 'lucide-astro';

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;

const features = [
  {
    title: t.features.f1_title,
    desc: t.features.f1_desc,
    icon: Zap,
    tone: 'green',
  },
  {
    title: t.features.f2_title,
    desc: t.features.f2_desc,
    icon: Shield,
    tone: 'blue',
  },
  {
    title: t.features.f3_title,
    desc: t.features.f3_desc,
    icon: Clock3,
    tone: 'sand',
  },
  {
    title: t.features.f4_title,
    desc: t.features.f4_desc,
    icon: Users,
    tone: 'red',
  },
];
---

<section class="features" id="applications">
  <div class="features__inner">
    <div class="features__head">
      <p class="features__eyebrow">{t.features.eyebrow}</p>
      <h2 class="features__title">{t.features.title}</h2>
    </div>

    <div class="features__grid">
      {
        features.map((feature) => {
          const Icon = feature.icon;

          return (
            <article class="feature-card">
              <div class={`feature-card__icon feature-card__icon--${feature.tone}`}>
                <Icon size={20} strokeWidth={2.1} />
              </div>

              <div class="feature-card__content">
                <h3 class="feature-card__title">{feature.title}</h3>
                <p class="feature-card__desc">{feature.desc}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding: 0 0 5rem;
    background: #f4f4f2;
  }

  .features__inner {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .features__head {
    margin-bottom: 1.5rem;
    max-width: 42rem;
  }

  .features__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.72rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--green-primary);
  }

  .features__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 0.98;
    font-weight: 700;
    color: var(--green-dark);
    text-transform: uppercase;
  }

  .features__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    padding: 1px;
    background: rgba(12, 26, 20, 0.08);
    border-radius: 1rem;
    overflow: hidden;
  }

  .feature-card {
    display: flex;
    gap: 1rem;
    padding: 1.4rem;
    background: var(--white);
    min-height: 12rem;
  }

  .feature-card__icon {
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 0.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .feature-card__icon--green {
    background: var(--green-pale);
    color: var(--green-primary);
  }

  .feature-card__icon--blue {
    background: #e6f1fb;
    color: #185fa5;
  }

  .feature-card__icon--sand {
    background: #faeeda;
    color: #854f0b;
  }

  .feature-card__icon--red {
    background: #fcebeb;
    color: #a32d2d;
  }

  .feature-card__content {
    min-width: 0;
  }

  .feature-card__title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.25;
    font-weight: 700;
    color: var(--green-dark);
  }

  .feature-card__desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.65;
    color: #4e5a53;
  }

  @media (max-width: 960px) {
    .features {
      padding: 0 0 4rem;
    }

    .features__grid {
      grid-template-columns: 1fr;
    }

    .feature-card {
      min-height: auto;
    }
  }

  @media (max-width: 640px) {
    .features__inner {
      width: min(100% - 1.25rem, 1200px);
    }

    .features__head {
      margin-bottom: 1.2rem;
    }

    .feature-card {
      padding: 1.1rem 1rem;
      gap: 0.85rem;
    }

    .feature-card__icon {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 0.7rem;
    }

    .feature-card__title {
      font-size: 0.96rem;
    }

    .feature-card__desc {
      font-size: 0.9rem;
      line-height: 1.6;
    }
  }
</style>