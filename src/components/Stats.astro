---
import type { TranslationKeys } from '../i18n/en';

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;

const stats = [
  { value: t.stats.s1_num, label: t.stats.s1_label },
  { value: t.stats.s2_num, label: t.stats.s2_label },
  { value: t.stats.s3_num, label: t.stats.s3_label },
  { value: t.stats.s4_num, label: t.stats.s4_label },
];
---

<section class="stats" aria-label="Key company statistics">
  <div class="stats__inner">
    {
      stats.map((stat) => (
        <article class="stats__item">
          <p class="stats__value">{stat.value}</p>
          <p class="stats__label">{stat.label}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .stats {
    background: var(--green-dark);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    padding: 0 1rem;
  }

  .stats__inner {
    width: min(1200px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stats__item {
    padding: 1.35rem 1.2rem 1.25rem;
    text-align: center;
    border-right: 1px solid var(--border-subtle);
  }

  .stats__item:last-child {
    border-right: none;
  }

  .stats__value {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    line-height: 0.95;
    font-weight: 700;
    color: var(--green-light);
    letter-spacing: 0.01em;
  }

  .stats__label {
    margin: 0.35rem auto 0;
    max-width: 12rem;
    font-size: 0.78rem;
    line-height: 1.35;
    font-weight: 500;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .stats__inner {
      grid-template-columns: repeat(2, 1fr);
    }

    .stats__item:nth-child(2) {
      border-right: none;
    }

    .stats__item:nth-child(1),
    .stats__item:nth-child(2) {
      border-bottom: 1px solid var(--border-subtle);
    }
  }

  @media (max-width: 560px) {
    .stats__inner {
      width: min(100% - 1.25rem, 1200px);
      grid-template-columns: 1fr 1fr;
    }

    .stats__item {
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
      padding: 1.15rem 1rem 1.05rem;
    }

    .stats__item:last-child {
      border-bottom: none;
    }

    .stats__label {
      max-width: none;
      font-size: 0.8rem;
    }
  }
</style>