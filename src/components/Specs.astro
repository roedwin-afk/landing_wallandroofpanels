---
import type { TranslationKeys } from "../i18n/en";

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;
---

<section class="specs" id="specs">
  <div class="specs__container">
    <div class="specs__header">
      <p class="specs__eyebrow">{t.specs.eyebrow}</p>
      <h2 class="specs__title">{t.specs.title}</h2>
      <p class="specs__intro">{t.specs.intro}</p>
    </div>

    <div class="specs__grid">
      {t.specs.items.map((item) => (
        <article class="spec-card">
          <span class="spec-card__label">{item.label}</span>
          <strong class="spec-card__value">{item.value}</strong>
        </article>
      ))}
    </div>

    <div class="specs__notes">
      {t.specs.notes.map((note) => (
        <article class="spec-note">
          <h3 class="spec-note__title">{note.title}</h3>
          <p class="spec-note__desc">{note.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .specs {
    padding: 5rem var(--container-padding, 1.25rem);
    background: #f4f4f2;
    
  }

  .specs__container {
    /* max-width: 1100px; */
    margin: 0 auto;
    width: min(1200px, calc(100% - 2rem));
  }

  .specs__header {
    max-width: 760px;
    margin-bottom: 2.5rem;
    
  }

  .specs__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--green-primary);
  }

  .specs__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--green-dark);
  }

  .specs__intro {
    margin: 1rem 0 0;
    max-width: 680px;
    font-size: 1rem;
    line-height: 1.75;
    color: #4d5652;
  }

  .specs__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .spec-card {
    padding: 1.25rem 1.1rem;
    border: 1px solid rgba(19, 52, 31, 0.08);
    background: #ffffff;
    border-radius: 0.9rem;
    box-shadow: 0 10px 30px rgba(16, 24, 20, 0.04);
  }

  .spec-card__label {
    display: block;
    margin-bottom: 0.65rem;
    font-size: 0.72rem;
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    color: #6c756f;
  }

  .spec-card__value {
    display: block;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--green-dark);
  }

  .specs__notes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .spec-note {
    padding: 1.4rem 1.2rem;
    border-radius: 0.9rem;
    background:
      linear-gradient(
        180deg,
        rgba(151, 196, 89, 0.08) 0%,
        rgba(151, 196, 89, 0.03) 100%
      );
    border: 1px solid rgba(151, 196, 89, 0.18);
  }

  .spec-note__title {
    margin: 0 0 0.6rem;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--green-dark);
  }

  .spec-note__desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #4d5652;
  }

  @media (max-width: 900px) {
    .specs__grid,
    .specs__notes {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .specs {
      padding: 4rem var(--container-padding, 1.25rem);
    }

    .specs__grid,
    .specs__notes {
      grid-template-columns: 1fr;
    }

    .specs__header {
      margin-bottom: 2rem;
    }

    .spec-card,
    .spec-note {
      border-radius: 0.8rem;
    }
  }
</style>